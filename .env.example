# Copy this file to .env and fill in the URL of your running backend (see /server).
#
# On the iOS Simulator or Android Emulator, "localhost" usually works.
# On a real phone running Expo Go, you MUST use your computer's LAN IP
# address instead (e.g. http://192.168.1.42:4000) — see README.md.
EXPO_PUBLIC_API_URL=http://localhost:4000
