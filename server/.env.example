# Copy this file to .env and fill in your real Anthropic API key.
# Get one at https://console.anthropic.com/settings/keys
# NEVER commit the real .env file or share this key publicly.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Current Anthropic docs list claude-sonnet-4-6 as a valid Claude API ID.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cloud AI is optional. The mobile app must also send allowCloudAi=true.

# Port the backend listens on. The Expo app's EXPO_PUBLIC_API_URL must match.
PORT=4000

# Comma-separated origins for production, e.g. https://app.billclear.ca,exp://192.168.1.42:8081
# Empty allows local/mobile development clients that do not send a browser Origin.
CORS_ORIGINS=

# Max JSON payload for base64 bill uploads. Netlify Functions have a lower request payload ceiling than a normal server.
JSON_BODY_LIMIT=6mb

# Per-IP scan requests per 15 minutes.
SCAN_RATE_LIMIT=30

# Keep true for demos; set false in production to avoid showing fake analysis for unsupported bills.
ALLOW_MOCK_ANALYSIS=true
